# Paddock Environment Configuration
# Copy this file to .env and fill in your values.

# ─── LLM API Keys (stored on host only, never sent to VM) ───
# At least one provider is required for agents to function.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (GPT)
# OPENAI_API_KEY=sk-xxxxx

# OpenRouter (multi-model)
# OPENROUTER_API_KEY=sk-or-xxxxx

# Google (Gemini)
# GOOGLE_API_KEY=xxxxx

# ─── Paddock Configuration ───

# Control Plane HTTP port
# PADDOCK_PORT=3100

# URL for Sidecar to reach Control Plane from inside VM
# PADDOCK_CONTROL_URL=http://host.internal:3100
