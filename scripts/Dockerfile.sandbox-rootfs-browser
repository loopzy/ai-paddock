ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/paddock/ms-playwright

COPY requirements.txt /tmp/paddock-requirements.txt

RUN apt-get update -o Acquire::Retries=5 \
  || apt-get update -o Acquire::Retries=5

RUN apt-get install -y --no-install-recommends -o Acquire::Retries=5 python3 python3-pip ca-certificates curl \
  && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --no-cache-dir -r /tmp/paddock-requirements.txt

RUN python3 -m playwright install --with-deps chromium

RUN mkdir -p /opt/paddock /workspace/.paddock/browser \
  && printf 'browser-runtime=1\n' > /opt/paddock/browser-runtime.ready
